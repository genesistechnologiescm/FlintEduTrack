# PRODUCTION (pilot) instance — copy to .env.production.local and fill in.
# NEVER commit the filled version. NEVER reuse demo-project keys here.
# These values come from the NEW Supabase project (see the Production Runbook).

# --- Database (Supabase → Connect → ORM/Prisma) ---
DATABASE_URL="postgresql://postgres.<NEW_REF>:<URL_ENCODED_PASSWORD>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<NEW_REF>:<URL_ENCODED_PASSWORD>@<region>.pooler.supabase.com:5432/postgres"

# --- Supabase app keys (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://<NEW_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret-key>"

# --- One-shot bootstrap: the pilot school + its first admin ---
BOOTSTRAP_SCHOOL_NAME="<Official school name>"
BOOTSTRAP_SCHOOL_REGION="<North-West | South-West | Centre | ...>"
BOOTSTRAP_SCHOOL_TOWN="<Town>"
# BOOTSTRAP_SCHOOL_CRISIS=1
BOOTSTRAP_ADMIN_NAME="<Principal's full name>"
BOOTSTRAP_ADMIN_PHONE="<6XXXXXXXX or +2376XXXXXXXX>"
BOOTSTRAP_ADMIN_PIN="<5 digits — NOT 12345>"
# BOOTSTRAP_ADMIN_TITLE="Principal"

# --- Web Push (generate FRESH for production: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY="<new-vapid-public-key>"
VAPID_PRIVATE_KEY="<new-vapid-private-key>"
VAPID_SUBJECT="mailto:officialkaisy@gmail.com"

# --- Chariot AI tutor (optional at pilot start) ---
# GEMINI_API_KEY="<google-ai-studio-key>"
