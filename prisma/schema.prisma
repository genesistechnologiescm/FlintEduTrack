// EduTrack — Phase 1 schema (see Architecture/06_Database_Schema.md + 07_Auth_Flow.md)
// Privacy is enforced by Supabase RLS policies applied AFTER this push (see prisma/rls.sql).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Enums ─────────────────────────
enum Lang {
  EN
  FR
}

enum SchoolRole {
  ADMIN
  TEACHER
}

enum StreamType {
  SCIENCES
  ARTS
  COMMERCIAL
  TECHNICAL
}

enum EnrollmentStatus {
  ACTIVE
  TRANSFERRED
  ARCHIVED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  PRE_AUTHORISED
}

enum SetBy {
  TEACHER
  ADMIN
  SYSTEM
}

enum ParentRelation {
  MOTHER
  FATHER
  GUARDIAN
  OTHER
}

enum ChannelType {
  PUSH
  WHATSAPP
  SMS
  VOICE
}

// Declared at enrolment: what can this parent's phone do? Drives the router's
// cost profile — smartphone parents are free (push), SMS-only parents cost money,
// and VOICE_ONLY parents (can't read SMS) get a text-to-speech call in their
// preferred language.
enum ContactCapability {
  SMARTPHONE
  WHATSAPP
  SMS_ONLY
  VOICE_ONLY
}

enum ChannelStatus {
  ACTIVE
  FAILING
  DISABLED
}

enum Criticality {
  CRITICAL
  ROUTINE
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum WelfareStatus {
  OPEN
  MONITORING
  AT_RISK
  ESCALATED_NATIONAL
  RESOLVED
}

enum WelfareEventType {
  ABSENCE_TRIGGER
  SMS_SENT
  MEETING_SUGGESTED
  MEETING_SCHEDULED
  STAFF_ASSIGNED
  HOME_VISIT
  OUTCOME_LOGGED
  SUSPENSION
  NOTE
}

// ───────────────────────── Identity ─────────────────────────
model User {
  id            String             @id // = auth.users.id
  phone         String             @unique
  displayName   String
  preferredLang Lang               @default(EN)
  contactCapability ContactCapability?
  authProvisionedAt DateTime? // set when a phone+PIN auth login was minted for this user (parents start without one)
  isFlintAdmin  Boolean            @default(false)
  isGovernment  Boolean            @default(false) // ministry account — read-only aggregate layer
  status        String             @default("active")
  createdAt     DateTime           @default(now())
  deletedAt     DateTime?
  memberships   SchoolMembership[]
  parentLinks   ParentLink[]
  channels      ParentChannel[]
  teaching      TimetableSlot[]    @relation("SlotTeacher")
  devices       AuthDevice[]
  authoredAnnouncements Announcement[]        @relation("AuthoredAnnouncements")
  announcementReceipts  AnnouncementReceipt[] @relation("AnnouncementReceipts")
  parentThreads MessageThread[]               @relation("ParentThreads")
  staffThreads  MessageThread[]               @relation("StaffThreads")
  sentMessages  Message[]                     @relation("SentMessages")
  authoredResources LessonResource[]          @relation("AuthoredResources")
  paymentsMade  Payment[]                     @relation("PaymentsMade")
  correctionRequests GradeCorrection[]        @relation("CorrectionRequests")
  gateCheckIns  GateCheckIn[]                 @relation("GateCheckIns")
  handoverNotes HandoverNote[]                @relation("HandoverNotes")
}

// ───────────────────────── Tenant + calendar ─────────────────────────
model School {
  id           String             @id @default(uuid())
  name         String
  region       String
  division     String?
  town         String?
  contactPhone String?
  logoUrl      String?
  isCrisisZone Boolean            @default(false)
  isTest       Boolean            @default(false) // sandbox school: excluded from national stats + exports
  status       String             @default("active")
  createdAt    DateTime           @default(now())
  deletedAt    DateTime?
  memberships  SchoolMembership[]
  years        AcademicYear[]
  classes      ClassGroup[]
  subjects     Subject[]
  slots        TimetableSlot[]
  enrollments  Enrollment[]
  announcements Announcement[]
  threads      MessageThread[]
  resources    LessonResource[]
  feeItems     FeeItem[]
  payments     Payment[]
  calendarEvents CalendarEvent[]
  @@index([region])
}

// Admin scope — what an ADMIN may administer (P2: "each scoped").
// FULL = everything; FINANCE = fees/payments/reminders; WELFARE = welfare,
// excused absences, wellbeing. Enforced server-side in every admin action.
enum AdminScope {
  FULL
  FINANCE
  WELFARE
}

model SchoolMembership {
  id        String     @id @default(uuid())
  userId    String
  schoolId  String
  role      SchoolRole
  title     String? // job title for display (Principal, Bursar, …); role is the permission level
  adminScope AdminScope @default(FULL) // meaningful for ADMIN rows only
  status    String     @default("active")
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  school    School     @relation(fields: [schoolId], references: [id])
  @@unique([userId, schoolId, role])
  @@index([schoolId])
  @@index([userId])
}

model AcademicYear {
  id        String       @id @default(uuid())
  schoolId  String
  label     String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean      @default(false)
  school    School       @relation(fields: [schoolId], references: [id])
  terms     Term[]
  classes   ClassGroup[]
  @@index([schoolId])
}

model Term {
  id             String          @id @default(uuid())
  academicYearId String
  label          String
  order          Int // 1..3 (Cameroon: 3 terms/year)
  sequenceCount  Int             @default(2) // CONFIRMED: 2 sequences/term -> 6/year
  startDate      DateTime
  endDate        DateTime
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  slots          TimetableSlot[]
  feeItems       FeeItem[]
  @@index([academicYearId])
}

// ───────────────────────── Academic structure ─────────────────────────
model ClassGroup {
  id             String          @id @default(uuid())
  schoolId       String
  academicYearId String
  name           String
  formLevel      Int
  streamType     StreamType?
  isGceClass     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  deletedAt      DateTime?
  school         School          @relation(fields: [schoolId], references: [id])
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  slots          TimetableSlot[]
  enrollments    Enrollment[]
  announcements  Announcement[]
  resources      LessonResource[]
  feeItems       FeeItem[]
  handoverNotes  HandoverNote[]
  @@index([schoolId])
  @@index([academicYearId])
}

model Subject {
  id         String          @id @default(uuid())
  schoolId   String
  name       String
  code       String?
  streamType StreamType?
  school     School          @relation(fields: [schoolId], references: [id])
  slots      TimetableSlot[]
  grades     Grade[]
  resources  LessonResource[]
  @@unique([schoolId, name])
  @@index([schoolId])
}

model TimetableSlot {
  id            String              @id @default(uuid())
  schoolId      String
  termId        String
  classGroupId  String
  subjectId     String
  teacherUserId String
  dayOfWeek     Int
  startTime     String
  endTime       String
  room          String?
  school        School              @relation(fields: [schoolId], references: [id])
  term          Term                @relation(fields: [termId], references: [id])
  classGroup    ClassGroup          @relation(fields: [classGroupId], references: [id])
  subject       Subject             @relation(fields: [subjectId], references: [id])
  teacher       User                @relation("SlotTeacher", fields: [teacherUserId], references: [id])
  sessions      AttendanceSession[]
  @@unique([termId, teacherUserId, dayOfWeek, startTime])
  @@index([schoolId])
  @@index([classGroupId])
  @@index([teacherUserId])
}

// ───────────────────────── Students + enrollment + guardianship ─────────────────────────
model Student {
  id          String                 @id @default(uuid())
  firstName   String
  lastName    String
  dob         DateTime?
  gender      String?
  photoUrl    String?
  createdAt   DateTime               @default(now())
  deletedAt   DateTime?
  enrollments Enrollment[]
  parentLinks ParentLink[]
  records     AttendanceRecord[]
  auths       AbsenceAuthorisation[]
  cases       WelfareCase[]
  grades      Grade[]
  threads     MessageThread[]
  payments    Payment[]
  account     StudentAccount?
  wellbeing   WellbeingSnapshot[]
}

// Weekly wellbeing snapshot — a teacher's pastoral read per student (Phase 3).
// Human judgment beside the attendance-derived risk score: it catches the child
// who attends but is withdrawing. One row per student per ISO week (upserted).
enum WellbeingLevel {
  ENGAGED
  NEUTRAL
  NEEDS_ATTENTION
}

model WellbeingSnapshot {
  id          String         @id @default(uuid())
  schoolId    String
  studentId   String
  weekStart   DateTime       @db.Date
  level       WellbeingLevel
  note        String?
  setByUserId String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  student     Student        @relation(fields: [studentId], references: [id])
  @@unique([studentId, weekStart])
  @@index([schoolId, weekStart])
}

model Enrollment {
  id           String           @id @default(uuid())
  studentId    String
  schoolId     String
  classGroupId String
  streamType   StreamType?
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime         @default(now())
  departedAt   DateTime?
  student      Student          @relation(fields: [studentId], references: [id])
  school       School           @relation(fields: [schoolId], references: [id])
  classGroup   ClassGroup       @relation(fields: [classGroupId], references: [id])
  @@unique([studentId, schoolId, classGroupId])
  @@index([schoolId])
  @@index([classGroupId])
  @@index([studentId])
}

model ParentLink {
  id             String         @id @default(uuid())
  parentUserId   String
  studentId      String
  schoolId       String
  relationship   ParentRelation @default(GUARDIAN)
  isPrimary      Boolean        @default(false)
  receivesAlerts Boolean        @default(true)
  pickupAuth     Boolean        @default(false)
  status         String         @default("active")
  createdAt      DateTime       @default(now())
  revokedAt      DateTime?
  parent         User           @relation(fields: [parentUserId], references: [id])
  student        Student        @relation(fields: [studentId], references: [id])
  @@unique([parentUserId, studentId, schoolId])
  @@index([parentUserId])
  @@index([studentId])
}

model AbsenceAuthorisation {
  id              String   @id @default(uuid())
  studentId       String
  schoolId        String
  fromDate        DateTime
  toDate          DateTime
  reason          String
  isExcusePostHoc Boolean  @default(false)
  authorisedBy    String
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id])
  @@index([studentId])
  @@index([schoolId, fromDate, toDate])
}

// ───────────────────────── Attendance ─────────────────────────
model AttendanceSession {
  id              String             @id @default(uuid())
  schoolId        String
  timetableSlotId String
  classGroupId    String
  subjectId       String
  teacherUserId   String
  date            DateTime           @db.Date
  periodStartAt   DateTime
  submittedAt     DateTime?
  isLate          Boolean            @default(false)
  idempotencyKey  String             @unique
  createdAt       DateTime           @default(now())
  slot            TimetableSlot      @relation(fields: [timetableSlotId], references: [id])
  records         AttendanceRecord[]
  @@unique([timetableSlotId, date])
  @@index([schoolId, date])
  @@index([teacherUserId, date])
}

model AttendanceRecord {
  id          String            @id @default(uuid())
  sessionId   String
  studentId   String
  status      AttendanceStatus  @default(PRESENT)
  setBy       SetBy             @default(TEACHER)
  setByUserId String
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  session     AttendanceSession @relation(fields: [sessionId], references: [id])
  student     Student           @relation(fields: [studentId], references: [id])
  @@unique([sessionId, studentId])
  @@index([studentId])
}

// ───────────────────────── Welfare (admin-only via RLS) ─────────────────────────
model WelfareCase {
  id              String         @id @default(uuid())
  studentId       String
  schoolId        String
  status          WelfareStatus  @default(OPEN)
  currentStage    Int            @default(1)
  assignedStaffId String?
  openedAt        DateTime       @default(now())
  lastActionAt    DateTime       @default(now())
  resolvedAt      DateTime?
  student         Student        @relation(fields: [studentId], references: [id])
  events          WelfareEvent[]
  @@index([schoolId, status])
  @@index([studentId])
}

model WelfareEvent {
  id            String           @id @default(uuid())
  welfareCaseId String
  type          WelfareEventType
  description   String
  actorUserId   String?
  occurredAt    DateTime         @default(now())
  metadata      Json?
  case          WelfareCase      @relation(fields: [welfareCaseId], references: [id])
  @@index([welfareCaseId])
}

model SuspensionLog {
  id           String   @id @default(uuid())
  studentId    String
  schoolId     String
  reason       String
  durationDays Int
  priorSteps   String
  decidedBy    String
  decidedAt    DateTime @default(now())
  @@index([schoolId])
  @@index([studentId])
}

// ───────────────────────── Notifications (see 05_Notification_Router.md) ─────────────────────────
model ParentChannel {
  id            String        @id @default(uuid())
  parentUserId  String
  type          ChannelType
  address       String
  optedIn       Boolean       @default(false)
  verified      Boolean       @default(false)
  lastSuccessAt DateTime?
  status        ChannelStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  parent        User          @relation(fields: [parentUserId], references: [id])
  @@index([parentUserId])
}

model NotificationLog {
  id               String         @id @default(uuid())
  parentUserId     String
  studentId        String?
  eventType        String
  criticality      Criticality
  channelAttempted ChannelType
  channelSucceeded ChannelType?
  costFcfa         Decimal        @default(0) @db.Decimal(8, 2)
  idempotencyKey   String         @unique
  deliveryStatus   DeliveryStatus @default(QUEUED)
  providerMsgId    String?
  serverSentAt     DateTime       @default(now())
  deliveredAt      DateTime?
  @@index([parentUserId])
  @@index([eventType, serverSentAt])
}

// ───────────────────────── Audit + conflict ─────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  schoolId    String?
  actorUserId String
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  reason      String?
  serverAt    DateTime @default(now())
  @@index([schoolId, serverAt])
  @@index([entityType, entityId])
}

// Records a data-processing consent — the school's at registration (the
// controller's lawful basis) and a guardian's acknowledgement of the privacy
// notice. Standalone table (like AuditLog) so the record survives even if the
// referenced school/user is later erased. policyVersion pins WHICH notice was
// agreed to, so a later revision can prompt for fresh consent.
model Consent {
  id              String   @id @default(uuid())
  scope           String // "SCHOOL" | "GUARDIAN"
  schoolId        String?
  userId          String? // the guardian, for GUARDIAN scope
  policyVersion   String
  grantedByUserId String
  grantedAt       DateTime @default(now())
  @@index([scope, schoolId])
  @@index([userId])
}

model ConflictLog {
  id             String    @id @default(uuid())
  entityType     String
  entityId       String
  resolution     String
  detail         String
  affectedUserId String
  resolvedAt     DateTime  @default(now())
  acknowledgedAt DateTime?
  @@index([affectedUserId])
}

// ───────────────────────── Auth (see 07_Auth_Flow.md) ─────────────────────────
model AuthDevice {
  id          String   @id @default(uuid())
  userId      String
  fingerprint String
  label       String?
  trusted     Boolean  @default(false)
  shared      Boolean  @default(false)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  @@unique([userId, fingerprint])
  @@index([userId])
}

model AuthAttempt {
  id      String   @id @default(uuid())
  phone   String
  ip      String?
  kind    String
  success Boolean
  at      DateTime @default(now())
  @@index([phone, at])
  @@index([ip, at])
}

// Assessment components — how a sequence mark is composed (Phase-2 spec:
// "CA component configuration"), e.g. Continuous Assessment 40 + Exam 60.
// Grade entry becomes component-wise when a school's weights total exactly 100;
// the WEIGHTED FINAL is what Grade.score stores (report cards etc. unchanged).
model AssessmentComponent {
  id        String    @id @default(uuid())
  schoolId  String
  name      String
  weight    Int // percent; entry activates only when the school's sum == 100
  order     Int       @default(1)
  deletedAt DateTime?
  @@index([schoolId])
}

// Grades — Cameroon sequence model (2 sequences/term, score out of 20).
model Grade {
  id        String   @id @default(uuid())
  studentId String
  subjectId String
  schoolId  String
  termId    String
  sequence  Int // 1 or 2 within the term
  score     Decimal  @db.Decimal(4, 2) // out of 20
  enteredBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  corrections GradeCorrection[]
  @@unique([studentId, subjectId, termId, sequence])
  @@index([schoolId, termId])
  @@index([studentId])
}

// Substitute handover note — a teacher leaves dated cover instructions on a
// class; any staff member covering it sees the note on the attendance screen
// until it expires (Phase-2 Communications spec).
model HandoverNote {
  id           String     @id @default(uuid())
  schoolId     String
  classGroupId String
  body         String
  activeUntil  DateTime   @db.Date
  authorUserId String
  createdAt    DateTime   @default(now())
  deletedAt    DateTime?
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id])
  author       User       @relation("HandoverNotes", fields: [authorUserId], references: [id])
  @@index([schoolId, classGroupId, activeUntil])
}

// Gate check-in — a staff member's timestamped arrival tap (one per day).
// Feeds staff-presence visibility now and the reliability index at scale.
model GateCheckIn {
  id        String   @id @default(uuid())
  schoolId  String
  userId    String
  date      DateTime @db.Date
  arrivedAt DateTime @default(now())
  user      User     @relation("GateCheckIns", fields: [userId], references: [id])
  @@unique([userId, date])
  @@index([schoolId, date])
}

// Digital library — platform-level study shelf (past GCE papers, syllabi,
// study guides). Deliberately NOT school-scoped: one curated national shelf,
// readable by every authenticated user. Writes are server-side only (curated).
enum LibraryKind {
  PAST_PAPER
  SYLLABUS
  STUDY_GUIDE
}

model LibraryItem {
  id        String      @id @default(uuid())
  kind      LibraryKind @default(PAST_PAPER)
  title     String
  subject   String
  exam      String? // e.g. "GCE O Level", "GCE A Level"
  year      Int?
  paper     Int?
  url       String?
  body      String?
  lang      Lang        @default(EN)
  // Contribution pipeline: teachers SUBMIT (PENDING), a Flint curator approves.
  // Only APPROVED items appear on the shelf — curation, not a junk drawer.
  status    String      @default("APPROVED") // PENDING | APPROVED | REJECTED
  schoolId  String? // submitting school (provenance), null = platform-curated
  createdBy String
  createdAt DateTime    @default(now())
  deletedAt DateTime?
  @@index([subject, year])
  @@index([kind])
  @@index([status])
}

// School calendar — staff publish term dates/events; parents and students read.
model CalendarEvent {
  id        String    @id @default(uuid())
  schoolId  String
  title     String
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  note      String?
  createdBy String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  school    School    @relation(fields: [schoolId], references: [id])
  @@index([schoolId, startDate])
}

// National exam calendar — government-managed country-wide dates (GCE, BEPC,
// results releases, registration deadlines). No schoolId: every school, parent
// and student sees these alongside their school events. Managed from
// /government/calendar (isGovernment users); exam dates are public information,
// so RLS allows public read (rls-national-events.sql).
model NationalEvent {
  id        String    @id @default(uuid())
  title     String
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  note      String?
  createdBy String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  @@index([startDate])
}

// Grade-correction workflow — once a grade is recorded, changing it requires an
// admin-approved correction (tamper-evident grading; Phase 2 spec). One PENDING
// request per grade at a time (enforced in code).
model GradeCorrection {
  id          String    @id @default(uuid())
  schoolId    String
  gradeId     String
  oldScore    Decimal   @db.Decimal(4, 2)
  newScore    Decimal   @db.Decimal(4, 2)
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedBy String
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  grade       Grade     @relation(fields: [gradeId], references: [id])
  requester   User      @relation("CorrectionRequests", fields: [requestedBy], references: [id])
  @@index([schoolId, status])
  @@index([gradeId])
}

// ───────────────────────── Messaging — school announcements ─────────────────────────
enum AnnouncementAudience {
  SCHOOL
  CLASS
  NATIONAL
}

// National notices carry a review workflow: ministry posts start
// PENDING_REVIEW and a Flint admin approves before the country sees them
// (school/class posts stay immediately PUBLISHED — the school is trusted on
// its own board).
enum AnnouncementStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

// A broadcast from school staff to parents (whole school or one class).
// Delivery + read state is per-parent in AnnouncementReceipt; push reuses the
// Notification Router's free web-push channel.
model Announcement {
  id           String                @id @default(uuid())
  schoolId     String? // null for NATIONAL notices (country-wide, no tenant)
  authorUserId String
  audience     AnnouncementAudience  @default(SCHOOL)
  status       AnnouncementStatus    @default(PUBLISHED)
  classGroupId String?
  title        String
  body         String
  reviewedBy   String? // Flint admin who approved/rejected a NATIONAL notice
  reviewedAt   DateTime?
  deleteReason String? // traceability: removals must say why
  createdAt    DateTime              @default(now())
  deletedAt    DateTime?
  school       School?               @relation(fields: [schoolId], references: [id])
  author       User                  @relation("AuthoredAnnouncements", fields: [authorUserId], references: [id])
  classGroup   ClassGroup?           @relation(fields: [classGroupId], references: [id])
  receipts     AnnouncementReceipt[]
  @@index([schoolId, createdAt])
  @@index([audience, status, createdAt])
}

model AnnouncementReceipt {
  id             String       @id @default(uuid())
  announcementId String
  parentUserId   String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  parent         User         @relation("AnnouncementReceipts", fields: [parentUserId], references: [id])
  @@unique([announcementId, parentUserId])
  @@index([parentUserId, createdAt])
}

// ───────────────────────── Messaging — parent ↔ staff threads ─────────────────────────
// A conversation between one parent and the school (any staff can pick it up;
// staffUserId records the latest staff responder). Optionally about one child.
model MessageThread {
  id            String    @id @default(uuid())
  schoolId      String
  parentUserId  String
  staffUserId   String?
  studentId     String?
  subject       String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  school        School    @relation(fields: [schoolId], references: [id])
  parent        User      @relation("ParentThreads", fields: [parentUserId], references: [id])
  staff         User?     @relation("StaffThreads", fields: [staffUserId], references: [id])
  student       Student?  @relation(fields: [studentId], references: [id])
  messages      Message[]
  @@index([schoolId, lastMessageAt])
  @@index([parentUserId, lastMessageAt])
}

model Message {
  id           String        @id @default(uuid())
  threadId     String
  senderUserId String
  fromParent   Boolean // true = parent wrote it, false = staff
  body         String
  createdAt    DateTime      @default(now())
  readAt       DateTime?
  thread       MessageThread @relation(fields: [threadId], references: [id])
  sender       User          @relation("SentMessages", fields: [senderUserId], references: [id])
  @@index([threadId, createdAt])
}

// ───────────────────────── E-learning — lesson resources (continuity) ─────────────────────────
// A lesson a teacher attaches to a subject so students/parents can learn even
// when they can't attend (crisis continuity). LINK = external URL, NOTE = inline
// text — both storage-free. Optionally scoped to one class; null = whole subject.
enum ResourceType {
  LINK
  NOTE
}

model LessonResource {
  id           String       @id @default(uuid())
  schoolId     String
  subjectId    String
  classGroupId String?
  type         ResourceType @default(LINK)
  title        String
  url          String?
  body         String?
  createdBy    String
  createdAt    DateTime     @default(now())
  deletedAt    DateTime?
  school       School       @relation(fields: [schoolId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  classGroup   ClassGroup?  @relation(fields: [classGroupId], references: [id])
  author       User         @relation("AuthoredResources", fields: [createdBy], references: [id])
  views        ResourceView[]
  @@index([schoolId, subjectId])
  @@index([classGroupId])
}

// Engagement telemetry: one row per student per resource per day (deduped —
// reach, not click-inflation). Server-written only; teachers read aggregates.
model ResourceView {
  id         String         @id @default(uuid())
  resourceId String
  userId     String
  day        DateTime       @db.Date
  createdAt  DateTime       @default(now())
  resource   LessonResource @relation(fields: [resourceId], references: [id])
  @@unique([resourceId, userId, day])
  @@index([resourceId])
}

// ───────────────────────── Fees & payments (mocked MoMo for the demo) ─────────────────────────
// Amounts in whole FCFA (no subunits). Payments record a mocked Mobile Money
// transaction — no real funds move; real PSP integration is a post-win swap.
enum PaymentMethod {
  MOMO
  CASH
  WAIVER // scholarship/hardship — reduces what a student owes, but is NOT cash collected
}

model FeeItem {
  id           String      @id @default(uuid())
  schoolId     String
  termId       String
  classGroupId String?
  label        String
  amount       Int // FCFA
  dueDate      DateTime?   @db.Date // past this + unpaid balance = overdue
  createdBy    String
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?
  school       School      @relation(fields: [schoolId], references: [id])
  term         Term        @relation(fields: [termId], references: [id])
  classGroup   ClassGroup? @relation(fields: [classGroupId], references: [id])
  @@index([schoolId, termId])
}

model Payment {
  id           String        @id @default(uuid())
  schoolId     String
  studentId    String
  amount       Int // FCFA
  method       PaymentMethod @default(MOMO)
  reference    String // mock MoMo transaction id
  paidByUserId String?
  note         String?
  createdAt    DateTime      @default(now())
  school       School        @relation(fields: [schoolId], references: [id])
  student      Student       @relation(fields: [studentId], references: [id])
  payer        User?         @relation("PaymentsMade", fields: [paidByUserId], references: [id])
  @@index([schoolId, createdAt])
  @@index([studentId])
}

// ───────────────────────── Student self-accounts ─────────────────────────
// Lets a student log in (loginCode + PIN, distinct `s…@edutrack.local` namespace)
// to see their own attendance, grades and lessons. id = auth.users.id.
model StudentAccount {
  id        String   @id
  studentId String   @unique
  schoolId  String
  loginCode String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  @@index([schoolId])
}

// ───────────────────────── E-learning — quizzes ─────────────────────────
// Multiple-choice quizzes (auto-graded). FK fields are plain strings (no Prisma
// relations to existing models) to keep the established models untouched; the
// only relations are internal to these three tables.
model Quiz {
  id           String         @id @default(uuid())
  schoolId     String
  subjectId    String
  classGroupId String?
  title        String
  dueAt        DateTime? // deadline (23:59 WAT of the chosen day); null = always open
  createdBy    String
  createdAt    DateTime       @default(now())
  deletedAt    DateTime?
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  @@index([schoolId])
  @@index([classGroupId])
}

model QuizQuestion {
  id           String @id @default(uuid())
  quizId       String
  order        Int
  prompt       String
  options      Json // string[]
  correctIndex Int
  quiz         Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  studentId   String
  schoolId    String
  score       Int // percentage 0–100
  answers     Json // number[] (chosen option index per question)
  submittedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  @@unique([quizId, studentId])
  @@index([studentId])
}
